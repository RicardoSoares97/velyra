        },
        "pt-PT": {
          "stringUnit": {
            "state": "translated",
            "value": "Um resumo técnico seguro para ajudar a diagnosticar a app. Nunca inclui tokens, credenciais, endereços completos de addons ou histórico de visualização."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
