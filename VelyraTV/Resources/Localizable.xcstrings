    "settings.icloud.delete.title": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Delete Velyra data from iCloud?"
          }
        },
        "pt-PT": {
          "stringUnit": {
            "state": "translated",
            "value": "Eliminar os dados da Velyra do iCloud?"
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "¿Eliminar los datos de Velyra de iCloud?"
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Supprimer les données Velyra d’iCloud ?"
          }
        }
      }
    },
    "settings.icloud.delete.body": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "This disables iCloud sync and removes Velyra settings stored in your private iCloud database. Local settings remain on this Apple TV."
          }
        },
        "pt-PT": {
          "stringUnit": {
            "state": "translated",
            "value": "Isto desativa a sincronização iCloud e remove as definições da Velyra guardadas na base privada do iCloud. As definições locais permanecem nesta Apple TV."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Esto desactiva la sincronización de iCloud y elimina los ajustes de Velyra guardados en la base privada de iCloud. Los ajustes locales permanecen en este Apple TV."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Cette action désactive la synchronisation iCloud et supprime les réglages Velyra stockés dans la base privée iCloud. Les réglages locaux restent sur cette Apple TV."
          }
        }
      }
    },
    "settings.icloud.delete.confirm": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Delete from iCloud"
          }
        },
        "pt-PT": {
          "stringUnit": {
            "state": "translated",
            "value": "Eliminar do iCloud"
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Eliminar de iCloud"
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Supprimer d’iCloud"
          }
        }
      }
    },
