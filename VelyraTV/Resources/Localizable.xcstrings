    "onboarding.welcome.eyebrow": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Welcome"
          }
        },
        "pt-PT": {
          "stringUnit": {
            "state": "translated",
            "value": "Bem-vindo"
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Bienvenido"
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Bienvenue"
          }
        }
      }
    },
    "onboarding.welcome.title": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Your stories, beautifully focused."
          }
        },
        "pt-PT": {
          "stringUnit": {
            "state": "translated",
            "value": "As tuas histórias, com tudo no sítio certo."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Tus historias, perfectamente enfocadas."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Vos histoires, magnifiquement mises en valeur."
          }
        }
      }
    },
    "onboarding.welcome.body": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Velyra brings your catalogues, progress and favourite content together in a cinematic experience built for the big screen."
          }
        },
        "pt-PT": {
          "stringUnit": {
            "state": "translated",
            "value": "A Velyra reúne os teus catálogos, progresso e conteúdos favoritos numa experiência cinematográfica criada para o grande ecrã."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Velyra reúne tus catálogos, progreso y contenido favorito en una experiencia cinematográfica creada para la gran pantalla."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Velyra réunit vos catalogues, votre progression et vos contenus favoris dans une expérience cinématographique pensée pour le grand écran."
          }
        }
      }
    },
    "onboarding.personal.eyebrow": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Made for you"
          }
        },
        "pt-PT": {
          "stringUnit": {
            "state": "translated",
            "value": "Feita para ti"
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Hecha para ti"
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Pensée pour vous"
          }
        }
      }
    },
    "onboarding.personal.title": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "A home screen that learns your rhythm."
          }
        },
        "pt-PT": {
          "stringUnit": {
            "state": "translated",
            "value": "Um ecrã inicial que acompanha o teu ritmo."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Una pantalla de inicio que sigue tu ritmo."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Un écran d’accueil qui suit votre rythme."
          }
        }
      }
    },
    "onboarding.personal.body": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Continue watching, discover new titles and move naturally between films, series and your library — without unnecessary complexity."
          }
        },
        "pt-PT": {
          "stringUnit": {
            "state": "translated",
            "value": "Continua a ver, descobre novos títulos e navega naturalmente entre filmes, séries e a tua biblioteca — sem complexidade desnecessária."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Sigue viendo, descubre nuevos títulos y navega de forma natural entre películas, series y tu biblioteca, sin complejidad innecesaria."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Reprenez votre lecture, découvrez de nouveaux titres et naviguez naturellement entre films, séries et bibliothèque, sans complexité inutile."
          }
        }
      }
    },
    "onboarding.icloud.eyebrow": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Your Apple ecosystem"
          }
        },
        "pt-PT": {
          "stringUnit": {
            "state": "translated",
            "value": "O teu ecossistema Apple"
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Tu ecosistema Apple"
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Votre écosystème Apple"
          }
        }
      }
    },
    "onboarding.icloud.title": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Your settings follow your Apple ID."
          }
        },
        "pt-PT": {
          "stringUnit": {
            "state": "translated",
            "value": "As tuas definições acompanham o teu Apple ID."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Tus ajustes siguen tu Apple ID."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Vos réglages suivent votre identifiant Apple."
          }
        }
      }
    },
    "onboarding.icloud.body": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "There is no separate Velyra account. When iCloud is available, themes, languages, addons and app preferences stay synchronised privately across your devices."
          }
        },
        "pt-PT": {
          "stringUnit": {
            "state": "translated",
            "value": "Não existe uma conta Velyra separada. Quando o iCloud está disponível, os temas, idiomas, addons e preferências ficam sincronizados de forma privada entre os teus dispositivos."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "No existe una cuenta Velyra separada. Cuando iCloud está disponible, los temas, idiomas, addons y preferencias se sincronizan de forma privada entre tus dispositivos."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Il n’existe pas de compte Velyra distinct. Lorsque iCloud est disponible, les thèmes, langues, extensions et préférences restent synchronisés de manière privée entre vos appareils."
          }
        }
      }
    },
    "onboarding.trakt.eyebrow": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Optional Trakt connection"
          }
        },
        "pt-PT": {
          "stringUnit": {
            "state": "translated",
            "value": "Ligação opcional ao Trakt"
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Conexión opcional con Trakt"
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Connexion Trakt facultative"
          }
        }
      }
    },
    "onboarding.trakt.title": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Your viewing history, always in sync."
          }
        },
        "pt-PT": {
          "stringUnit": {
            "state": "translated",
            "value": "O teu histórico, sempre sincronizado."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Tu historial, siempre sincronizado."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Votre historique, toujours synchronisé."
          }
        }
      }
    },
    "onboarding.trakt.body": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Connect Trakt to synchronise watch history, watchlists and playback progress. You can also do this later in Settings."
          }
        },
        "pt-PT": {
          "stringUnit": {
            "state": "translated",
            "value": "Liga o Trakt para sincronizares o histórico, a lista para ver e o progresso de reprodução. Também podes fazê-lo mais tarde nas Definições."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Conecta Trakt para sincronizar el historial, la lista de seguimiento y el progreso. También puedes hacerlo más tarde en Ajustes."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Connectez Trakt pour synchroniser l’historique, la liste de suivi et la progression. Vous pourrez aussi le faire plus tard dans Réglages."
          }
        }
      }
    },
    "onboarding.ready.eyebrow": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Everything is ready"
          }
        },
        "pt-PT": {
          "stringUnit": {
            "state": "translated",
            "value": "Está tudo pronto"
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Todo está listo"
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Tout est prêt"
          }
        }
      }
    },
    "onboarding.ready.title": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Press play on something extraordinary."
          }
        },
        "pt-PT": {
          "stringUnit": {
            "state": "translated",
            "value": "Carrega no play de algo extraordinário."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Dale al play a algo extraordinario."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Lancez quelque chose d’extraordinaire."
          }
        }
      }
    },
    "onboarding.ready.body": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Velyra is ready to become your personal media space. Add your authorised sources, connect Trakt whenever you want and make it yours."
          }
        },
        "pt-PT": {
          "stringUnit": {
            "state": "translated",
            "value": "A Velyra está pronta para ser o teu espaço pessoal de media. Adiciona as tuas fontes autorizadas, liga o Trakt quando quiseres e personaliza tudo à tua maneira."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Velyra está lista para ser tu espacio multimedia personal. Añade tus fuentes autorizadas, conecta Trakt cuando quieras y hazla tuya."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Velyra est prête à devenir votre espace multimédia personnel. Ajoutez vos sources autorisées, connectez Trakt quand vous le souhaitez et personnalisez-la."
          }
        }
      }
    },
