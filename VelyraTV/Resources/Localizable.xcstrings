          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Un résumé technique respectueux de la vie privée pour diagnostiquer l’app. Il n’inclut jamais de jetons, d’identifiants, d’adresses complètes d’extensions ni d’historique de visionnage."
          }
        }
      }
