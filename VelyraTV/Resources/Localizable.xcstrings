    "icloud.status.unknown": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "iCloud status could not be determined"
          }
        },
        "pt-PT": {
          "stringUnit": {
            "state": "translated",
            "value": "Não foi possível determinar o estado do iCloud"
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "No se pudo determinar el estado de iCloud"
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Impossible de déterminer l’état d’iCloud"
          }
        }
      }
    },
    "icloud.privacy.explanation": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Velyra never receives your Apple ID email or password."
          }
        },
        "pt-PT": {
          "stringUnit": {
            "state": "translated",
            "value": "A Velyra nunca recebe o email nem a palavra-passe do teu Apple ID."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Velyra nunca recibe el correo ni la contraseña de tu Apple ID."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Velyra ne reçoit jamais l’adresse e-mail ni le mot de passe de votre identifiant Apple."
          }
        }
      }
    },
    "icloud.noLoginRequired": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "No Velyra login required"
          }
        },
        "pt-PT": {
          "stringUnit": {
            "state": "translated",
            "value": "Sem login Velyra"
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Sin inicio de sesión Velyra"
          }
        },
