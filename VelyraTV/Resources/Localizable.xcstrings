    "onboarding.simple.body": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Velyra chooses the best compatible source, keeps the original audio and uses subtitles for your region. You can change everything while watching."
          }
        },
        "pt-PT": {
          "stringUnit": {
            "state": "translated",
            "value": "A Velyra escolhe a melhor fonte compatível, mantém o áudio original e usa legendas para a tua região. Podes alterar tudo durante a reprodução."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Velyra elige la mejor fuente compatible, mantiene el audio original y usa subtítulos para tu región. Puedes cambiarlo todo durante la reproducción."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Velyra choisit la meilleure source compatible, conserve l’audio original et utilise les sous-titres de votre région. Vous pouvez tout modifier pendant la lecture."
          }
        }
      }
    },
